<nav class="relative bg-white py-4 px-6 md:px-24 shadow-sm z-50">
  <div class="container mx-auto flex items-center justify-between">

    <!-- Logo -->
    <div class="flex-shrink-0">
      <a href="/" class="no-underline">
        {% if section.settings.logo_image != blank %}
          <img src="{{ section.settings.logo_image | image_url: width: 101, height: 28 }}"
            width="101" height="28" alt="Logo" class="h-10 object-contain" />
        {% else %}
          <span class="font-figtree text-4xl tracking-tight text-gray-900" style="letter-spacing: -0.05em;">
            {{ section.settings.logo_text | default: "SORA" }}
          </span>
        {% endif %}
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden md:flex flex-grow justify-center">
      <ul class="flex space-x-5 lg:space-x-6">
        {% for block in section.blocks %}
          {% if block.type == 'menu_item' %}
            {% assign is_active = false %}
            {% if request.path == block.settings.link %}
              {% assign is_active = true %}
            {% endif %}

            <li class="relative group">
              <a href="{{ block.settings.link | default: '#' }}"
                 class="relative flex items-center text-[16px] leading-[26px] no-underline font-normal text-gray-700 hover:text-gray-900
                 {% if is_active %} text-black after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-black after:content-[''] {% endif %}">
                {{ block.settings.label }}

                {% if block.settings.has_dropdown and block.settings.show_dropdown_icon %}
                  <span class="ml-1">
                    {% render 'icon-menu-dropdown' %}
                  </span>
                {% endif %}
              </a>

              {% if block.settings.has_dropdown %}
                <!-- Mega Menu dropdown -->
              

<!-- Mega Menu dropdown -->
<div
  class="absolute left-1/2 top-full transform -translate-x-1/2  bg-white pt-12 pb-8 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
>
  <div class="mx-auto px-6 overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-[160px_1px_160px_1px_repeat(2,minmax(0,1fr))] gap-x-6 ">
    
      <!-- Bold Headings -->
      <div class="flex flex-col gap-6">
        {% for i in (1..4) %}
          {% assign heading_key = 'mega_heading_' | append: i %}
          {% assign heading = block.settings[heading_key] %}
          {% assign heading_link_key = 'mega_heading_link_' | append: i %}
          {% assign heading_link = block.settings[heading_link_key] %}
          {% if heading != blank %}
            <a href="{{ heading_link }}" class="text-zinc-800 text-xl font-semibold leading-7 hover:underline">{{ heading }}</a>
          {% endif %}
        {% endfor %}
      </div>

      <div class="w-px h-full bg-gray-200"></div>

      <!-- Submenu Items -->
      <div class="flex flex-col gap-6">
        {% for i in (1..4) %}
          {% assign submenu_label_key = 'submenu_label_' | append: i %}
          {% assign sub_label = block.settings[submenu_label_key] %}
          {% assign submenu_link_key = 'submenu_link_' | append: i %}
          {% assign sub_link = block.settings[submenu_link_key] %}
          {% if sub_label != blank %}
            <a href="{{ sub_link }}" class="text-zinc-800 text-base font-normal leading-6 hover:underline">{{ sub_label }}</a>
          {% endif %}
        {% endfor %}
      </div>

      <div class="w-px h-full bg-gray-200"></div>

      <!-- Product Card 1 -->
      {% assign product_key = 'manual_product_1' %}
      {% assign product = all_products[block.settings[product_key]] %}
      {% if product != blank %}
        <div class="p-4 bg-neutral-100 flex flex-col gap-4  w-full">
          <a href="{{ product.url }}">
            <img src="{{ product.featured_image | image_url: width: 262 }}" alt="{{ product.title }}" class="h-72 w-full object-cover" />
          </a>
          <div class="flex flex-col gap-1">
            <a href="{{ product.url }}" class="text-zinc-800 text-lg font-semibold leading-7 hover:underline">{{ product.title }}</a>
            <div class="text-zinc-800 text-2xl font-bold leading-9">{{ product.price | money }}</div>
            <div class="flex gap-1">
              {% for variant in product.variants limit: 2 %}
                <div class="w-3 h-3 rounded-full" style="background-color: {{ variant.option1 | downcase }}"></div>
              {% endfor %}
            </div>
          </div>
          <a href="{{ product.url }}" class="mt-2 px-6 py-3 border border-slate-500 text-slate-500 text-base flex items-center justify-center gap-1 hover:bg-slate-100">
            Add To Cart
          </a>
        </div>
      {% endif %}

      <!-- Product Card 2 -->
      {% assign product_key = 'manual_product_2' %}
      {% assign product = all_products[block.settings[product_key]] %}
      {% if product != blank %}
        <div class="p-4 bg-neutral-100 flex flex-col gap-4  w-full">
          <a href="{{ product.url }}">
            <img src="{{ product.featured_image | image_url: width: 262 }}" alt="{{ product.title }}" class="h-72 w-full object-cover" />
          </a>
          <div class="flex flex-col gap-1">
            <a href="{{ product.url }}" class="text-zinc-800 text-lg font-semibold leading-7 hover:underline">{{ product.title }}</a>
            <div class="text-zinc-800 text-2xl font-bold leading-9">{{ product.price | money }}</div>
            <div class="flex gap-1">
              {% for variant in product.variants limit: 2 %}
                <div class="w-3 h-3 rounded-full" style="background-color: {{ variant.option1 | downcase }}"></div>
              {% endfor %}
            </div>
          </div>
          <a href="{{ product.url }}" class="mt-2 px-6 py-3 border border-slate-500 text-slate-500 text-base flex items-center justify-center gap-1 hover:bg-slate-100">
            Add To Cart
          </a>
        </div>
      {% endif %}

    </div>
  </div>
</div>



              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>

    <!-- Icons -->
    <div class="flex items-center space-x-3 ml-auto">
      {% if section.settings.show_search %}
        <a href="#" class="flex items-center justify-center w-6 h-6 hover:bg-gray-50">
          {% render 'icon-search' %}
        </a>
      {% endif %}
      {% if section.settings.show_cart %}
        <a href="/cart" class="flex items-center justify-center w-6 h-6 hover:bg-gray-50">
          {% render 'icon-shop-cart' %}
        </a>
      {% endif %}
      {% if section.settings.show_account %}
        <a href="/account" class="flex items-center justify-center w-6 h-6 hover:bg-gray-50">
          {% render 'icon-user' %}
        </a>
      {% endif %}
    </div>

    <!-- Mobile Menu Toggle -->
    <div class="md:hidden flex items-center">
      <button id="mobile-menu-button" aria-label="Toggle Mobile Menu" class="text-gray-700 hover:text-gray-900 focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white py-4 shadow-md">
    <ul class="flex flex-col space-y-2 px-6">
      {% for block in section.blocks %}
        {% if block.type == 'menu_item' %}
          <li>
            <div class="flex justify-between items-center py-2">
              <a href="{{ block.settings.link | default: '#' }}" class="text-gray-700 no-underline hover:bg-gray-100 block flex-grow">
                {{ block.settings.label }}
              </a>

              {% if block.settings.has_dropdown %}
                <!-- Mobile submenu toggle button -->
                <button aria-label="Toggle submenu" class="ml-2 mobile-submenu-toggle focus:outline-none">
                  <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </button>
              {% endif %}
            </div>

            {% if block.settings.has_dropdown %}
              <ul class="mobile-submenu hidden flex flex-col pl-4 border-l border-gray-200">
                {% for i in (1..4) %}
                  {% assign submenu_label_key = "submenu_label_" | append: i %}
                  {% assign sub_label = block.settings[submenu_label_key] %}
                  {% assign submenu_link_key = "submenu_link_" | append: i %}
                  {% assign sub_link = block.settings[submenu_link_key] %}
                  {% if sub_label != blank %}
                    <li>
                      <a href="{{ sub_link }}" class="block py-2 text-gray-700 hover:bg-gray-100 no-underline">
                        {{ sub_label }}
                      </a>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</nav>

<script src="{{ 'header.js' | asset_url }}" defer></script>





{% schema %}
{
  "name": "Main Navbar",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text (used if no image)",
      "default": "SORA"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show Cart Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show Account Icon",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Menu Label",
          "default": "Man"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Menu Link"
        },
        {
          "type": "checkbox",
          "id": "has_dropdown",
          "label": "Has Dropdown?",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_dropdown_icon",
          "label": "Show Dropdown Icon?",
          "default": true
        },

        { "type": "text", "id": "mega_heading_1", "label": "Bold Heading 1" },
        { "type": "url", "id": "mega_heading_link_1", "label": "Bold Heading 1 Link" },
        { "type": "text", "id": "mega_heading_2", "label": "Bold Heading 2" },
        { "type": "url", "id": "mega_heading_link_2", "label": "Bold Heading 2 Link" },
        { "type": "text", "id": "mega_heading_3", "label": "Bold Heading 3" },
        { "type": "url", "id": "mega_heading_link_3", "label": "Bold Heading 3 Link" },
        { "type": "text", "id": "mega_heading_4", "label": "Bold Heading 4" },
        { "type": "url", "id": "mega_heading_link_4", "label": "Bold Heading 4 Link" },

        { "type": "text", "id": "submenu_label_1", "label": "Submenu Item 1 Label" },
        { "type": "url", "id": "submenu_link_1", "label": "Submenu Item 1 Link" },
        { "type": "text", "id": "submenu_label_2", "label": "Submenu Item 2 Label" },
        { "type": "url", "id": "submenu_link_2", "label": "Submenu Item 2 Link" },
        { "type": "text", "id": "submenu_label_3", "label": "Submenu Item 3 Label" },
        { "type": "url", "id": "submenu_link_3", "label": "Submenu Item 3 Link" },
        { "type": "text", "id": "submenu_label_4", "label": "Submenu Item 4 Label" },
        { "type": "url", "id": "submenu_link_4", "label": "Submenu Item 4 Link" },

        {
          "type": "product",
          "id": "manual_product_1",
          "label": "Product Card 1"
        },
        {
          "type": "product",
          "id": "manual_product_2",
          "label": "Product Card 2"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default Navigation",
      "blocks": [
        { "type": "menu_item", "settings": { "label": "Man" } },
        { "type": "menu_item", "settings": { "label": "Woman" } },
        { "type": "menu_item", "settings": { "label": "New Apparels" } },
        { "type": "menu_item", "settings": { "label": "Seasons" } },
        { "type": "menu_item", "settings": { "label": "Blogs" } },
        { "type": "menu_item", "settings": { "label": "Contact" } }
      ]
    }
  ]
}
{% endschema %}


