<nav class="bg-white py-4 px-6 md:px-24 shadow-sm relative z-50">
  <div class="container mx-auto flex items-center justify-between">

    <!-- Logo -->
    <div class="flex-shrink-0">
      <a href="/" class="no-underline">
        {% if section.settings.logo_image != blank %}
          <img src="{{ section.settings.logo_image | image_url: width: 101, height: 28 }}"
            width="101" height="28" alt="Logo" class="h-10 object-contain" />
        {% else %}
          <span class="font-figtree text-4xl tracking-tight text-gray-900" style="letter-spacing: -0.05em;">
            {{ section.settings.logo_text | default: "SORA" }}
          </span>
        {% endif %}
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden md:flex flex-grow justify-center">
      <ul class="flex space-x-5 lg:space-x-6">

        <!-- Customizer Menu Blocks -->
        {% for block in section.blocks %}
          {% if block.type == 'menu_item' %}
            {% assign is_active = false %}
            {% if request.path == block.settings.link %}
              {% assign is_active = true %}
            {% endif %}

            <li class="relative group">
           <a href="{{ block.settings.link | default: '#' }}"
  class="relative flex items-center text-[16px] leading-[26px] no-underline group font-normal text-gray-700 hover:text-gray-900">
  
  <span class="relative
    {% if is_active %}
      text-black after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-black after:content-['']
    {% endif %}">
    {{ block.settings.label }}
  </span>

  {% if block.settings.has_dropdown and block.settings.show_dropdown_icon %}
    <span class="ml-1">
      {% render 'icon-menu-dropdown' %}
    </span>
  {% endif %}
</a>



              {% if block.settings.has_dropdown %}
                <ul class="hidden group-hover:block absolute left-0 mt-2 w-48 bg-white shadow-lg rounded-md overflow-hidden z-10 py-1 text-[16px]">
                  {% for i in (1..3) %}
                    {% capture lbl %}dropdown_label_{{ i }}{% endcapture %}
                    {% capture lnk %}dropdown_link_{{ i }}{% endcapture %}
                    {% assign sub_label = block.settings[lbl] %}
                    {% assign sub_link = block.settings[lnk] %}
                    {% if sub_label != blank %}
                      <li>
                        <a href="{{ sub_link | default: '#' }}"
                           class="block px-4 py-2 text-gray-700 hover:bg-gray-100 no-underline">
                          {{ sub_label }}
                        </a>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}

        <!-- Admin Navigation -->
        {% assign nav_links = linklists.sora-menu.links %}
        {% for link in nav_links %}
          {% assign is_active = false %}
          {% if request.path == link.url %}
            {% assign is_active = true %}
          {% endif %}

          <li class="relative group">
            <a href="{{ link.url }}"
              class="relative flex items-center text-[16px] leading-[26px] no-underline
              {% if is_active %}
                text-black font-normal after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-black
              {% else %}
                text-gray-700 hover:text-gray-900 font-normal
              {% endif %}">
              {{ link.title }}
            </a>

            {% if link.links != blank %}
              <ul class="hidden group-hover:block absolute left-0 mt-2 w-48 bg-white shadow-lg rounded-md overflow-hidden z-10 py-1 text-[16px]">
                {% for child in link.links %}
                  <li>
                    <a href="{{ child.url }}" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 no-underline">
                      {{ child.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}

      </ul>
    </div>

    <!-- Icons -->
    <div class="flex items-center space-x-3 ml-auto">
      {% if section.settings.show_search %}
        <a href="#" class="flex items-center justify-center w-6 h-6 hover:bg-gray-50">
          {% render 'icon-search' %}
        </a>
      {% endif %}
      {% if section.settings.show_cart %}
        <a href="/cart" class="flex items-center justify-center w-6 h-6 hover:bg-gray-50">
          {% render 'icon-shop-cart' %}
        </a>
      {% endif %}
      {% if section.settings.show_account %}
        <a href="/account" class="flex items-center justify-center w-6 h-6 hover:bg-gray-50">
          {% render 'icon-user' %}
        </a>
      {% endif %}
    </div>

    <!-- Mobile Menu Toggle -->
    <div class="md:hidden flex items-center">
      <button id="mobile-menu-button" class="text-gray-700 hover:text-gray-900 focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white py-4 shadow-md">
    <ul class="flex flex-col space-y-2 px-6">
      {% for block in section.blocks %}
        {% if block.type == 'menu_item' %}
          <li>
            <a href="{{ block.settings.link | default: '#' }}"
              class="block py-2 text-gray-700 hover:bg-gray-100 no-underline">
              {{ block.settings.label }}
            </a>
          </li>
        {% endif %}
      {% endfor %}
      {% for link in nav_links %}
        <li>
          <a href="{{ link.url }}" class="block py-2 text-gray-700 hover:bg-gray-100 no-underline">
            {{ link.title }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</nav>


{% schema %}
{
  "name": "Main Navbar",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text (used if no image)",
      "default": "SORA"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show Cart Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show Account Icon",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Menu Label",
          "default": "Man"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Menu Link"
        },
        {
          "type": "checkbox",
          "id": "has_dropdown",
          "label": "Has Dropdown?",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_dropdown_icon",
          "label": "Show Dropdown Icon?",
          "default": true
        },
        {
          "type": "text",
          "id": "dropdown_label_1",
          "label": "Dropdown Item 1 Label"
        },
        {
          "type": "url",
          "id": "dropdown_link_1",
          "label": "Dropdown Item 1 Link"
        },
        {
          "type": "text",
          "id": "dropdown_label_2",
          "label": "Dropdown Item 2 Label"
        },
        {
          "type": "url",
          "id": "dropdown_link_2",
          "label": "Dropdown Item 2 Link"
        },
        {
          "type": "text",
          "id": "dropdown_label_3",
          "label": "Dropdown Item 3 Label"
        },
        {
          "type": "url",
          "id": "dropdown_link_3",
          "label": "Dropdown Item 3 Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default Navigation",
      "blocks": [
        { "type": "menu_item", "settings": { "label": "Man" } },
        { "type": "menu_item", "settings": { "label": "Woman" } },
        { "type": "menu_item", "settings": { "label": "New Apparels" } },
        { "type": "menu_item", "settings": { "label": "Seasons" } },
        { "type": "menu_item", "settings": { "label": "Blogs" } },
        { "type": "menu_item", "settings": { "label": "Contact" } }
      ]
    }
  ]
}
{% endschema %}
