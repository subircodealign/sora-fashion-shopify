{% render 'banner',
  background_image: section.settings.background_image,
  badge_text: section.settings.badge_text,
  heading: section.settings.heading,
  subheading: section.settings.subheading,
  primary_button_text: section.settings.primary_button_text,
  primary_button_link: section.settings.primary_button_link,
  secondary_button_text: section.settings.secondary_button_text,
  secondary_button_link: section.settings.secondary_button_link
%}


{% schema %}
{
  "name": "Woman Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Just Arrived"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Wardrobe With Our New Arrivals"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Woman Hero Banner"
    }
  ]
}
{% endschema %}
