<!-- Banner Section -->
{% assign banner_image = section.settings.banner_image | default: article.image %}

<section class="relative w-full">
  {% if banner_image %}
    <div class="w-full h-[400px] md:h-[583px] bg-cover bg-center" style="background-image: url('{{ banner_image | image_url: 'master' }}');"></div>
  {% endif %}
</section>


<section class="relative z-10 -mt-[104px] mb-24 px-[171px]">
  <div class=" p-12 bg-white inline-flex flex-col justify-center items-center gap-8 w-full">
    

    <div class="w-[552px] flex flex-col justify-start items-center gap-3">
      <div class="self-stretch text-center text-zinc-500 text-lg font-normal leading-7 font-[Figtree]">
        {{ article.published_at | date: "%d %B %Y" }}
      </div>
      <h1 class="self-stretch text-center text-zinc-800 text-5xl font-normal leading-[64px] font-catalina">
        {{ article.title }}
      </h1>
    </div>

    <div class="self-stretch text-justify text-zinc-500 text-base font-normal leading-relaxed font-[Figtree]">
      {{ article.excerpt_or_content | strip_html }}
    </div>

 
    {% if article.image %}
      <img class="self-stretch h-[511px] object-cover" src="{{ article.image | image_url: '1002x511' }}" width=full height="511" alt="{{ article.title }}" />
    {% endif %}

  
    <div class="self-stretch text-justify text-zinc-500 text-base font-normal leading-relaxed font-[Figtree]">
      {{ article.content }}
    </div>

 
    {% if article.tags.size > 0 %}
      <div class="self-stretch text-justify text-zinc-500 text-base font-medium leading-relaxed font-[Figtree]">
        Tags:
        {% for tag in article.tags %}
          {{ tag }}{% unless forloop.last %}, {% endunless %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>


<section class="mt-24">
  {% render 'blog-related', current_article: article %}
</section>


{% schema %}
{
  "name": "Blog Article",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image (optional)",
      "info": "Overrides article featured image"
    }
  ]
}
{% endschema %}
